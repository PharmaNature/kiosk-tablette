# Copiez ce fichier en "keystore.properties" (sans .example) à la racine du projet,
# puis renseignez vos vraies valeurs. Ce fichier ne doit JAMAIS être committé.
#
# Générez d'abord le keystore (une seule fois) :
#   keytool -genkeypair -v -keystore release.keystore -alias kiosk \
#       -keyalg RSA -keysize 4096 -validity 10000 \
#       -dname "CN=PharmaNature Kiosk, O=PharmaNature, C=FR"

storeFile=../release.keystore
storePassword=CHANGEZ_MOI
keyAlias=kiosk
keyPassword=CHANGEZ_MOI
