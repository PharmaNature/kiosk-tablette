<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="64dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="16dp"
            android:adjustViewBounds="true"
            android:contentDescription="@string/app_name"
            android:src="@drawable/logo_pharmanature" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:text="@string/admin_title"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- URL -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/admin_url_label"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/inputUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:importantForAutofill="no"
            android:inputType="textUri" />

        <!-- PIN -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/admin_pin_label"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/inputPin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:importantForAutofill="no"
            android:inputType="numberPassword" />

        <!-- Tapotements -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/admin_taps_label"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/inputTaps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:importantForAutofill="no"
            android:inputType="number" />

        <!-- Coin -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/admin_corner_label"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/groupCorner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/cornerTL"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/corner_tl" />

            <RadioButton
                android:id="@+id/cornerTR"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/corner_tr" />

            <RadioButton
                android:id="@+id/cornerBL"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/corner_bl" />

            <RadioButton
                android:id="@+id/cornerBR"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/corner_br" />
        </RadioGroup>

        <CheckBox
            android:id="@+id/checkRemote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="@string/admin_remote_label" />

        <!-- Action principale -->
        <Button
            android:id="@+id/btnLaunch"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:backgroundTint="@color/kiosk_green"
            android:text="@string/admin_launch"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnStop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/admin_stop" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="28dp"
            android:layout_marginBottom="16dp"
            android:background="#DDDDDD" />

        <Button
            android:id="@+id/btnDeprovision"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#B00020"
            android:text="@string/admin_deprovision"
            android:textColor="#FFFFFF" />

    </LinearLayout>
</ScrollView>
