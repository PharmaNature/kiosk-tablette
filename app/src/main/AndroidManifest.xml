<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="false"
        android:icon="@drawable/ic_app"
        android:roundIcon="@drawable/ic_app"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:networkSecurityConfig="@xml/network_security_config"
        android:theme="@style/Theme.Kiosk"
        android:enableOnBackInvokedCallback="true">

        <!-- Activity kiosk = launcher HOME. Le verrouillage (lock task) est piloté
             EXCLUSIVEMENT par code (startLockTask/stopLockTask) : pas de lockTaskMode
             auto, pour éviter les états verrouillés coincés. -->
        <activity
            android:name=".KioskActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:excludeFromRecents="true"
            android:configChanges="orientation|screenSize|keyboardHidden|screenLayout|smallestScreenSize|density|uiMode">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.HOME" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Écran d'administration (accessible uniquement après saisie du PIN). -->
        <activity
            android:name=".AdminActivity"
            android:exported="false"
            android:theme="@style/Theme.Kiosk.Admin" />

        <!-- DeviceAdminReceiver requis pour devenir Device Owner. -->
        <receiver
            android:name=".KioskAdminReceiver"
            android:permission="android.permission.BIND_DEVICE_ADMIN"
            android:exported="true">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
